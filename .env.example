# Copy this file to .env and fill in whichever provider keys you have.
# The eval config degrades gracefully — providers without a key are skipped.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Pins the interpreter promptfoo shells out to for `type: python` assertions.
# Point this at the project venv so it doesn't fall back to a system Python
# that's missing the packages in requirements.txt.
PROMPTFOO_PYTHON=.venv/Scripts/python.exe

# CI gating (see .github/workflows/eval.yml) — promptfoo exits 100 if the
# eval's pass rate falls below this percentage.
PROMPTFOO_PASS_RATE_THRESHOLD=95

# Optional: only needed if you enable sharing/the hosted promptfoo viewer.
# PROMPTFOO_API_KEY=

# Optional: overrides assertions/tone_rubric.py's LLM-judge grader model.
# Defaults to gemini-2.5-flash-lite (a separate free-tier quota bucket from
# gemini-2.5-flash, the pinned generation provider) if unset. Requires
# GOOGLE_API_KEY regardless of which model is named here — the grader is
# always called via the Gemini API.
# TONE_GRADER_MODEL=gemini-2.5-flash-lite
